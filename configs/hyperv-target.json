{
    "igvm": {
        "hyper-v": {
            "output": "coconut-hyperv.igvm",
            "platforms": [
                "snp",
                "tdp",
                "vsm"
            ],
            "policy": "0x30000",
            "comport": "3",
            "measure": "print"
        }
    },
    "kernel": {
        "svsm": {
            "features": "vtpm,enable-console-log",
            "binary": false
        },
        "bldr": {
            "manifest": "boot/bldr/Cargo.toml",
            "binary": true,
            "objcopy": "binary"
        },
        "tdx-stage1": {
            "manifest": "stage1/Cargo.toml",
            "binary": true,
            "objcopy": "binary"
        }
    },
    "firmware": {
        "env": "HV_FW_FILE"
    },
    "fs": {
        "modules": {
            "userinit": {
                "path": "/init"
            }
        }
    }
}
