{
    "igvm": {
        "hyper-v": {
            "output": "coconut-test-hyperv.igvm",
            "platforms": [
                "snp",
                "tdp",
                "vsm"
            ],
            "policy": "0x30000",
            "comport": "3",
            "measure": "print"
        }
    },
    "kernel": {
        "svsm": {
            "type": "test",
            "toolchain": "nightly",
            "no_default_features": true,
            "env": {
                "RUSTDOC": "true",
                "LINK_TEST": "1"
            }
        },
        "bldr": {
            "manifest": "boot/bldr/Cargo.toml",
            "binary": true,
            "objcopy": "binary"
        },
        "tdx-stage1": {
            "manifest": "stage1/Cargo.toml",
            "binary": true,
            "objcopy": "binary"
        }
    },
    "firmware": {},
    "fs": {
        "modules": {}
    }
}
