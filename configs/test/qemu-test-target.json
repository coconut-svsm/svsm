{
    "igvm": {
        "qemu": {
            "output": "coconut-test-qemu.igvm",
            "platforms": [
                "snp",
                "tdp",
                "native"
            ],
            "measure": "print"
        }
    },
    "kernel": {
        "svsm": {
            "type": "test",
            "toolchain": "nightly",
            "no_default_features": true,
            "env": {
                "RUSTDOC": "true",
                "LINK_TEST": "1"
            }
        },
        "bldr": {
            "manifest": "boot/bldr/Cargo.toml",
            "binary": true,
            "objcopy": "binary"
        },
        "tdx-stage1": {
            "manifest": "stage1/Cargo.toml",
            "binary": true,
            "objcopy": "binary"
        }
    },
    "firmware": {},
    "fs": {
        "modules": {
            "uapi_tester": {
                "path": "/test/uapi_tester",
                "type": "test",
                "toolchain": "nightly",
                "no_default_features": true,
                "env": {
                    "RUSTDOC": "true",
                    "LINK_TEST": "1"
                }
            }
        }
    }
}
