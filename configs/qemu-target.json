{
    "igvm": {
        "qemu": {
            "output": "coconut-qemu.igvm",
            "platforms": [
                "snp",
                "tdp",
                "native"
            ],
            "policy": "0x30000",
            "measure": "print",
            "check-kvm": true
        }
    },
    "kernel": {
        "svsm": {
            "features": "vtpm,uefivars",
            "binary": false
        },
        "bldr": {
            "manifest": "boot/bldr/Cargo.toml",
            "binary": true,
            "objcopy": "binary"
        },
        "tdx-stage1": {
            "manifest": "stage1/Cargo.toml",
            "binary": true,
            "objcopy": "binary"
        }
    },
    "firmware": {
        "env": "FW_FILE"
    },
    "fs": {
        "modules": {
            "userinit": {
                "path": "/init"
            }
        }
    }
}
